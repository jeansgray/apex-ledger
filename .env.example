# Apex Ledger (proprietary app — not MiroFish .env)
APEX_DATA_DIR=./data
APEX_LEDGER_DB=./data/ledger.db
APEX_SKILLS_DIR=./.cursor/skills
APEX_SKILL_MANIFEST=./skills/manifest.json

# MiroFish simulation backend (AGPL service boundary — HTTP only)
MIROFISH_BASE_URL=http://127.0.0.1:5001
MIROFISH_DEFAULT_SIMULATION_ID=

# Kronos forecast service (MIT boundary — HTTP only)
KRONOS_BASE_URL=http://127.0.0.1:5002
APEX_USE_KRONOS=true
KRONOS_FORECAST_DAYS=30

# MiroFish live simulation (required for SimulationFactory background jobs)
# Run: python3 scripts/configure_keys.py after setting these
LLM_API_KEY=
ZEP_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Optional: LLM for council agents when not delegating to MiroFish report agent

# Optional: bank sync via Plaid (not required for demo / manual entry)
# Sign up: https://dashboard.plaid.com/signup
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
